import customtkinter as ctk

# Configurações
ctk.set_appearance_mode("dark")
ctk.set_default_color_theme("blue")

# Janela principal
app = ctk.CTk()
app.title("Sistema de Login")
app.geometry("500x400")


# =========================
# FUNÇÕES DE NAVEGAÇÃO
# =========================

def mostrar_menu():
    frame_cadastro.pack_forget()
    frame_login.pack_forget()
    frame_menu.pack(fill="both", expand=True)


def mostrar_cadastro():
    frame_menu.pack_forget()
    frame_cadastro.pack(fill="both", expand=True)


def mostrar_login():
    frame_menu.pack_forget()
    frame_login.pack(fill="both", expand=True)


# =========================
# TELA MENU
# =========================

frame_menu = ctk.CTkFrame(app)

titulo = ctk.CTkLabel(
    frame_menu,
    text="Bem-vindo",
    font=("Arial", 24, "bold")
)
titulo.pack(pady=40)

btn_cadastro = ctk.CTkButton(
    frame_menu,
    text="Cadastrar Usuário",
    command=mostrar_cadastro
)
btn_cadastro.pack(pady=10)

btn_login = ctk.CTkButton(
    frame_menu,
    text="Fazer Login",
    command=mostrar_login
)
btn_login.pack(pady=10)


# =========================
# TELA CADASTRO
# =========================

frame_cadastro = ctk.CTkFrame(app)

titulo_cadastro = ctk.CTkLabel(
    frame_cadastro,
    text="Cadastro de Usuário",
    font=("Arial", 22, "bold")
)
titulo_cadastro.pack(pady=20)

entry_usuario = ctk.CTkEntry(
    frame_cadastro,
    placeholder_text="Digite o usuário"
)
entry_usuario.pack(pady=10)

entry_senha = ctk.CTkEntry(
    frame_cadastro,
    placeholder_text="Digite a senha",
    show="*"
)
entry_senha.pack(pady=10)

btn_voltar1 = ctk.CTkButton(
    frame_cadastro,
    text="Voltar",
    command=mostrar_menu
)
btn_voltar1.pack(pady=20)


# =========================
# TELA LOGIN
# =========================

frame_login = ctk.CTkFrame(app)

titulo_login = ctk.CTkLabel(
    frame_login,
    text="Login",
    font=("Arial", 22, "bold")
)
titulo_login.pack(pady=20)

entry_login_usuario = ctk.CTkEntry(
    frame_login,
    placeholder_text="Usuário"
)
entry_login_usuario.pack(pady=10)

entry_login_senha = ctk.CTkEntry(
    frame_login,
    placeholder_text="Senha",
    show="*"
)
entry_login_senha.pack(pady=10)

btn_voltar2 = ctk.CTkButton(
    frame_login,
    text="Voltar",
    command=mostrar_menu
)
btn_voltar2.pack(pady=20)


# Tela inicial
frame_menu.pack(fill="both", expand=True)

app.mainloop()