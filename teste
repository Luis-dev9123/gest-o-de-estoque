import customtkinter as ctk

janela = ctk.CTk()
janela.geometry("400x200")

# 1. Criando o campo de preenchimento
entrada = ctk.CTkEntry(
    master=janela, 
    placeholder_text="Digite seu nome...", # Texto que some ao clicar
    width=300,                             # Largura do campo
    height=35,                             # Altura do campo
    corner_radius=10                       # Arredondamento das bordas
)
entrada.pack(pady=20)

# Função para pegar o valor digitado
def mostrar_texto():
    texto = entrada.get() # O método .get() captura o conteúdo
    print(f"O usuário digitou: {texto}")

botao = ctk.CTkButton(janela, text="Enviar", command=mostrar_texto)
botao.pack()

janela.mainloop()
